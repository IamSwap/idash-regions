{
  "version": 8,
  "name": "idash-light",
  "glyphs": "http://localhost:8080/fonts/{fontstack}/{range}.pbf",
  "sources": {
    "v": { "type": "vector", "url": "pmtiles://v" },
    "dem": {
      "type": "raster-dem",
      "tiles": ["https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png"],
      "encoding": "terrarium", "tileSize": 256, "maxzoom": 13
    }
  },
  "layers": [
    { "id": "bg", "type": "background", "paint": { "background-color": "#eef1f5" } },

    { "id": "earth", "type": "fill", "source": "v", "source-layer": "earth",
      "paint": { "fill-color": "#e8edf3" } },

    { "id": "lc-farmland", "type": "fill", "source": "v", "source-layer": "landcover",
      "filter": ["in", ["get", "kind"], ["literal", ["farmland", "farm", "cropland"]]],
      "paint": { "fill-color": "#edf0df", "fill-opacity": 0.6 } },
    { "id": "lc-wood", "type": "fill", "source": "v", "source-layer": "landcover",
      "filter": ["in", ["get", "kind"], ["literal", ["forest", "wood", "tree"]]],
      "paint": { "fill-color": "#d6e6d2", "fill-opacity": 0.8 } },
    { "id": "lc-grass", "type": "fill", "source": "v", "source-layer": "landcover",
      "filter": ["in", ["get", "kind"], ["literal", ["grassland", "grass", "meadow", "scrub", "heath"]]],
      "paint": { "fill-color": "#e2ecdb", "fill-opacity": 0.7 } },
    { "id": "lc-sand", "type": "fill", "source": "v", "source-layer": "landcover",
      "filter": ["in", ["get", "kind"], ["literal", ["sand", "beach", "dune"]]],
      "paint": { "fill-color": "#efe6cf", "fill-opacity": 0.8 } },
    { "id": "lc-barren", "type": "fill", "source": "v", "source-layer": "landcover",
      "filter": ["in", ["get", "kind"], ["literal", ["barren", "bare_rock", "scree", "rock", "fell"]]],
      "paint": { "fill-color": "#e6e3db", "fill-opacity": 0.7 } },
    { "id": "lc-wetland", "type": "fill", "source": "v", "source-layer": "landcover",
      "filter": ["in", ["get", "kind"], ["literal", ["wetland", "marsh", "swamp", "mangrove"]]],
      "paint": { "fill-color": "#d8e8e0", "fill-opacity": 0.7 } },
    { "id": "lc-glacier", "type": "fill", "source": "v", "source-layer": "landcover",
      "filter": ["in", ["get", "kind"], ["literal", ["glacier", "snow", "ice"]]],
      "paint": { "fill-color": "#f2f6fb", "fill-opacity": 0.9 } },

    { "id": "landuse-green", "type": "fill", "source": "v", "source-layer": "landuse",
      "filter": ["in", ["get", "kind"], ["literal", ["park", "forest", "wood", "nature_reserve", "garden", "golf_course", "grass", "meadow", "cemetery", "recreation_ground", "village_green"]]],
      "paint": { "fill-color": "#dcebd4", "fill-opacity": 0.8 } },
    { "id": "landuse-builtup", "type": "fill", "source": "v", "source-layer": "landuse",
      "filter": ["in", ["get", "kind"], ["literal", ["industrial", "commercial", "residential", "retail", "railway", "military", "aerodrome", "runway"]]],
      "minzoom": 9,
      "paint": { "fill-color": "#e6e9ef", "fill-opacity": 0.7 } },

    { "id": "hillshade", "type": "hillshade", "source": "dem", "minzoom": 6,
      "paint": { "hillshade-exaggeration": 0.35,
        "hillshade-shadow-color": "#7b8492", "hillshade-highlight-color": "#ffffff",
        "hillshade-accent-color": "#c6ccd6" } },

    { "id": "water", "type": "fill", "source": "v", "source-layer": "water",
      "paint": { "fill-color": "#aacdec" } },
    { "id": "waterway", "type": "line", "source": "v", "source-layer": "water",
      "filter": ["in", ["get", "kind"], ["literal", ["river", "stream", "canal", "drain", "ditch"]]],
      "minzoom": 11,
      "paint": { "line-color": "#7fb0d8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 0.4, 15, 1.6] } },

    { "id": "buildings", "type": "fill", "source": "v", "source-layer": "buildings",
      "minzoom": 14,
      "paint": { "fill-color": "#dde3ec", "fill-opacity": 0.9,
        "fill-outline-color": "#ccd4df" } },

    { "id": "rd-track", "type": "line", "source": "v", "source-layer": "roads",
      "filter": ["any", ["==", ["get", "kind"], "track"], ["==", ["get", "kind_detail"], "track"]],
      "minzoom": 12,
      "layout": { "line-cap": "round" },
      "paint": { "line-color": "#b39a6a", "line-dasharray": [2, 1.5],
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.5, 16, 2, 18, 3.5] } },
    { "id": "rd-path", "type": "line", "source": "v", "source-layer": "roads",
      "filter": ["in", ["get", "kind"], ["literal", ["path", "footway", "cycleway", "pedestrian"]]],
      "minzoom": 14,
      "paint": { "line-color": "#b6b2a6", "line-dasharray": [1.5, 1.5],
        "line-width": ["interpolate", ["linear"], ["zoom"], 14, 0.4, 18, 2] } },
    { "id": "rd-minor", "type": "line", "source": "v", "source-layer": "roads",
      "filter": ["in", ["get", "kind"], ["literal", ["minor_road", "other", "service"]]],
      "minzoom": 12,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": { "line-color": "#ffffff",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.4, 14, 1.0, 16, 3, 18, 7] } },
    { "id": "rd-medium", "type": "line", "source": "v", "source-layer": "roads",
      "filter": ["==", ["get", "kind"], "medium_road"], "minzoom": 10,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": { "line-color": "#ffffff",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.6, 13, 1.8, 16, 5, 18, 11] } },
    { "id": "rd-major", "type": "line", "source": "v", "source-layer": "roads",
      "filter": ["==", ["get", "kind"], "major_road"], "minzoom": 7,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": { "line-color": "#fbdf9c",
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.6, 11, 2.2, 14, 5, 18, 14] } },
    { "id": "rd-highway", "type": "line", "source": "v", "source-layer": "roads",
      "filter": ["==", ["get", "kind"], "highway"], "minzoom": 5,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": { "line-color": "#f6c969",
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 0.6, 9, 2, 12, 4, 16, 9, 18, 18] } },

    { "id": "rail", "type": "line", "source": "v", "source-layer": "roads",
      "filter": ["==", ["get", "kind"], "rail"], "minzoom": 11,
      "paint": { "line-color": "#b0b6c0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 0.5, 16, 1.6] } },

    { "id": "boundary", "type": "line", "source": "v", "source-layer": "boundaries",
      "filter": ["<=", ["get", "kind_detail"], 4], "minzoom": 4,
      "paint": { "line-color": "#a7b1c1", "line-dasharray": [3, 2],
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 0.5, 10, 1.2] } },

    { "id": "label-road", "type": "symbol", "source": "v", "source-layer": "roads",
      "filter": ["in", ["get", "kind"], ["literal", ["highway", "major_road", "medium_road"]]],
      "minzoom": 12,
      "layout": { "symbol-placement": "line", "text-font": ["Noto Sans Regular"],
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 9, 16, 12],
        "text-letter-spacing": 0.05, "symbol-spacing": 350 },
      "paint": { "text-color": "#586273", "text-halo-color": "#eef1f5", "text-halo-width": 1.4 } },

    { "id": "label-water", "type": "symbol", "source": "v", "source-layer": "water",
      "filter": ["has", "name"], "minzoom": 11,
      "layout": { "text-font": ["Noto Sans Regular"],
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-size": ["interpolate", ["linear"], ["zoom"], 11, 9, 15, 12],
        "text-max-width": 7 },
      "paint": { "text-color": "#3f6f9b", "text-halo-color": "#eef1f5", "text-halo-width": 1.2 } },

    { "id": "label-place-small", "type": "symbol", "source": "v", "source-layer": "places",
      "filter": ["in", ["get", "kind"], ["literal", ["village", "locality", "suburb", "neighbourhood", "hamlet"]]],
      "minzoom": 12,
      "layout": { "text-font": ["Noto Sans Regular"],
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 16, 13],
        "text-max-width": 7 },
      "paint": { "text-color": "#4a5263", "text-halo-color": "#eef1f5", "text-halo-width": 1.6 } },

    { "id": "label-place-town", "type": "symbol", "source": "v", "source-layer": "places",
      "filter": ["==", ["get", "kind"], "town"], "minzoom": 9,
      "layout": { "text-font": ["Noto Sans Regular"],
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-size": ["interpolate", ["linear"], ["zoom"], 9, 11, 14, 15],
        "text-max-width": 8 },
      "paint": { "text-color": "#2c3340", "text-halo-color": "#eef1f5", "text-halo-width": 1.8 } },

    { "id": "label-place-city", "type": "symbol", "source": "v", "source-layer": "places",
      "filter": ["in", ["get", "kind"], ["literal", ["city", "state_capital", "capital"]]],
      "minzoom": 5,
      "layout": { "text-font": ["Noto Sans Regular"],
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-size": ["interpolate", ["linear"], ["zoom"], 5, 12, 12, 20],
        "text-max-width": 8, "text-transform": "uppercase", "text-letter-spacing": 0.04 },
      "paint": { "text-color": "#1a2230", "text-halo-color": "#eef1f5", "text-halo-width": 2 } }
  ]
}
