{
  "version": 8,
  "name": "idash-dark",
  "glyphs": "http://localhost:8080/fonts/{fontstack}/{range}.pbf",
  "sources": { "v": { "type": "vector", "url": "pmtiles://v" } },
  "layers": [
    { "id": "bg", "type": "background", "paint": { "background-color": "#0b0e13" } },

    { "id": "earth", "type": "fill", "source": "v", "source-layer": "earth",
      "paint": { "fill-color": "#12161d" } },

    { "id": "landcover-wood", "type": "fill", "source": "v", "source-layer": "landcover",
      "filter": ["in", ["get", "kind"], ["literal", ["forest", "wood", "tree"]]],
      "paint": { "fill-color": "#13201a", "fill-opacity": 0.7 } },
    { "id": "landcover-grass", "type": "fill", "source": "v", "source-layer": "landcover",
      "filter": ["in", ["get", "kind"], ["literal", ["grassland", "grass", "meadow", "scrub"]]],
      "paint": { "fill-color": "#161c17", "fill-opacity": 0.6 } },

    { "id": "landuse-green", "type": "fill", "source": "v", "source-layer": "landuse",
      "filter": ["in", ["get", "kind"], ["literal", ["park", "forest", "wood", "nature_reserve", "garden", "golf_course", "grass", "meadow", "cemetery", "recreation_ground", "village_green"]]],
      "paint": { "fill-color": "#152019", "fill-opacity": 0.8 } },
    { "id": "landuse-builtup", "type": "fill", "source": "v", "source-layer": "landuse",
      "filter": ["in", ["get", "kind"], ["literal", ["industrial", "commercial", "residential", "retail", "railway", "military", "aerodrome", "runway"]]],
      "minzoom": 9,
      "paint": { "fill-color": "#151a22", "fill-opacity": 0.7 } },

    { "id": "water", "type": "fill", "source": "v", "source-layer": "water",
      "paint": { "fill-color": "#0c1a2b" } },

    { "id": "rd-minor", "type": "line", "source": "v", "source-layer": "roads",
      "filter": ["in", ["get", "kind"], ["literal", ["minor_road", "other", "service"]]],
      "minzoom": 12,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": { "line-color": "#262b34",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.4, 14, 1.0, 16, 3, 18, 7] } },
    { "id": "rd-path", "type": "line", "source": "v", "source-layer": "roads",
      "filter": ["==", ["get", "kind"], "path"], "minzoom": 14,
      "paint": { "line-color": "#23272f",
        "line-width": ["interpolate", ["linear"], ["zoom"], 14, 0.4, 18, 2] } },
    { "id": "rd-medium", "type": "line", "source": "v", "source-layer": "roads",
      "filter": ["==", ["get", "kind"], "medium_road"], "minzoom": 10,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": { "line-color": "#313945",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.6, 13, 1.8, 16, 5, 18, 11] } },
    { "id": "rd-major", "type": "line", "source": "v", "source-layer": "roads",
      "filter": ["==", ["get", "kind"], "major_road"], "minzoom": 7,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": { "line-color": "#3c4654",
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.6, 11, 2.2, 14, 5, 18, 14] } },
    { "id": "rd-highway", "type": "line", "source": "v", "source-layer": "roads",
      "filter": ["==", ["get", "kind"], "highway"], "minzoom": 5,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": { "line-color": "#4a5666",
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 0.6, 9, 2, 12, 4, 16, 9, 18, 18] } },

    { "id": "rail", "type": "line", "source": "v", "source-layer": "roads",
      "filter": ["==", ["get", "kind"], "rail"], "minzoom": 11,
      "paint": { "line-color": "#2c313b",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 0.5, 16, 1.6] } },

    { "id": "boundary", "type": "line", "source": "v", "source-layer": "boundaries",
      "filter": ["<=", ["get", "kind_detail"], 4], "minzoom": 4,
      "paint": { "line-color": "#39414e", "line-dasharray": [3, 2],
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 0.5, 10, 1.2] } },

    { "id": "label-road", "type": "symbol", "source": "v", "source-layer": "roads",
      "filter": ["in", ["get", "kind"], ["literal", ["highway", "major_road", "medium_road"]]],
      "minzoom": 12,
      "layout": { "symbol-placement": "line", "text-font": ["Noto Sans Regular"],
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 9, 16, 12],
        "text-letter-spacing": 0.05, "symbol-spacing": 350 },
      "paint": { "text-color": "#9aa3b2", "text-halo-color": "#0b0e13", "text-halo-width": 1.4 } },

    { "id": "label-place-small", "type": "symbol", "source": "v", "source-layer": "places",
      "filter": ["in", ["get", "kind"], ["literal", ["village", "locality", "suburb", "neighbourhood"]]],
      "minzoom": 12,
      "layout": { "text-font": ["Noto Sans Regular"],
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 16, 13],
        "text-max-width": 7 },
      "paint": { "text-color": "#aeb6c4", "text-halo-color": "#0b0e13", "text-halo-width": 1.6 } },

    { "id": "label-place-town", "type": "symbol", "source": "v", "source-layer": "places",
      "filter": ["==", ["get", "kind"], "town"], "minzoom": 9,
      "layout": { "text-font": ["Noto Sans Regular"],
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-size": ["interpolate", ["linear"], ["zoom"], 9, 11, 14, 15],
        "text-max-width": 8 },
      "paint": { "text-color": "#cdd3de", "text-halo-color": "#0b0e13", "text-halo-width": 1.8 } },

    { "id": "label-place-city", "type": "symbol", "source": "v", "source-layer": "places",
      "filter": ["in", ["get", "kind"], ["literal", ["city", "state_capital", "capital"]]],
      "minzoom": 5,
      "layout": { "text-font": ["Noto Sans Regular"],
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-size": ["interpolate", ["linear"], ["zoom"], 5, 12, 12, 20],
        "text-max-width": 8, "text-transform": "uppercase", "text-letter-spacing": 0.04 },
      "paint": { "text-color": "#e7ebf2", "text-halo-color": "#0b0e13", "text-halo-width": 2 } }
  ]
}
